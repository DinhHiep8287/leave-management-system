# ===== Environment & Secrets =====
.env
.env.local
.env.*.local
*.pem
*.key

# ===== Java / Gradle (backend) =====
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*
replay_pid*

# Gradle
.gradle/
build/
# Keep the Gradle wrapper jar at any depth (needed for ./gradlew on fresh clones / CI).
# A root-anchored "!gradle/wrapper/..." does NOT match backend/gradle/wrapper/...
!**/gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Maven (phòng khi dùng tạm)
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup

# ===== Node / Frontend =====
node_modules/
dist/
dist-ssr/
*.local
.vite/
.cache/
coverage/
*.tsbuildinfo
# tsc -b emits these from vite.config.ts (composite project) — build artifacts, not source
frontend/vite.config.js
frontend/vite.config.d.ts

# ===== IDE =====
# IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Eclipse
.classpath
.project
.settings/
.metadata/
bin/

# NetBeans
nbproject/
nbbuild/
nbdist/
.nb-gradle/

# ===== OS =====
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ===== Docker =====
# Không ignore Dockerfile và docker-compose
# Chỉ ignore volumes local nếu có
docker-data/
.docker/

# ===== Test & Coverage =====
.nyc_output/
*.lcov
jacoco.exec
test-results/
playwright-report/

# ===== Misc =====
*.tmp
*.bak
*.swp
*.swo
*~
.history/

# ===== Claude Code skills (Windows junctions to .agents/skills) =====
# Auto-load convenience only; the real skills live in .agents/skills/.
# Junctions don't track cleanly in git on Windows — recreate locally if needed.
.claude/skills/

# pnpm package store created by in-container installs (bind-mounted)
frontend/.pnpm-store/
