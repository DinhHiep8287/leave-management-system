FROM mirror.gcr.io/library/node:20-alpine

RUN corepack enable && corepack prepare pnpm@9.12.1 --activate

WORKDIR /app

# Install deps in a cacheable layer
COPY package.json ./
COPY pnpm-lock.yaml* ./
RUN pnpm install

EXPOSE 5173

# Source mounted via docker-compose volume
CMD ["pnpm", "dev", "--host", "0.0.0.0"]
