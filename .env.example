# ============================================================
# .env.example — copy thành .env và điền giá trị thật
# KHÔNG commit file .env vào git
# ============================================================

# ----- Database -----
POSTGRES_DB=leave_management
POSTGRES_USER=leave_admin
POSTGRES_PASSWORD=changeme_in_local
POSTGRES_PORT=5432

# ----- Backend (Spring Boot) -----
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Database URL backend sử dụng (dùng tên service Docker, KHÔNG dùng localhost)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/leave_management
SPRING_DATASOURCE_USERNAME=leave_admin
SPRING_DATASOURCE_PASSWORD=changeme_in_local

# ----- JWT -----
# Sinh chuỗi ngẫu nhiên >=32 ký tự, KHÔNG dùng giá trị mẫu này ở production
# JWT_ACCESS_EXPIRATION_MS = 15 phút, JWT_REFRESH_EXPIRATION_MS = 7 ngày
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ----- Frontend (Vite) -----
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Timezone & Locale -----
TZ=Asia/Ho_Chi_Minh
