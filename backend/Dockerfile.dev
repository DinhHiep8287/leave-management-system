FROM gradle:8.10-jdk21-alpine

WORKDIR /app

# Copy build files first to cache dependencies layer
COPY --chown=gradle:gradle build.gradle.kts settings.gradle.kts gradle.properties ./

# Pre-download dependencies
RUN gradle --no-daemon dependencies --refresh-dependencies || true

EXPOSE 8080 5005

# ENV JAVA_TOOL_OPTIONS="-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005"
ENV GRADLE_USER_HOME=/home/gradle/.gradle

# USER gradle

# Source mounted via docker-compose volume at /app
CMD ["gradle", "--no-daemon", "bootRun"]
