FROM gradle:8.10-jdk21-alpine

WORKDIR /app

# Pre-download dependencies in a cacheable layer
COPY build.gradle.kts settings.gradle.kts gradle.properties ./
RUN gradle --no-daemon dependencies --refresh-dependencies || true

EXPOSE 8080

# Container runs as root (image default). Source mounted at /app via docker-compose.
CMD ["gradle", "--no-daemon", "bootRun"]
