# ============================================================
# .env.prod.example — copy to .env for a production deploy.
# NEVER commit the real .env. Generate strong secrets.
# Used by docker-compose.prod.yml.
# ============================================================

# ----- Database -----
POSTGRES_DB=leave_management
POSTGRES_USER=leave_admin
# REQUIRED: a strong password (compose fails fast if unset).
POSTGRES_PASSWORD=

# ----- JWT (REQUIRED) -----
# Generate, e.g.: openssl rand -base64 48
# Must be >= 32 characters. Compose fails fast if unset.
JWT_SECRET=
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ----- CORS -----
# Public origin(s) allowed to call the API. With the single-host nginx setup
# the SPA and API share an origin, but set this to your real domain anyway.
APP_CORS_ALLOWED_ORIGINS=https://leave.example.com

# ----- Frontend -----
# Public port for the nginx-served SPA (maps to container :80).
FRONTEND_PORT=80
# API base URL baked into the SPA at build time. Keep "/api" for the single-host
# nginx proxy; for a split deploy set the API origin, e.g. https://api.example.com/api
VITE_API_BASE_URL=/api

# ----- Timezone -----
TZ=Asia/Ho_Chi_Minh
